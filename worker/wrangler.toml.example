name = "shinylive-d1-datatable-api"
main = "src/index.js"
compatibility_date = "2026-05-04"

[[d1_databases]]
binding = "SQL_TABLE_DB"
database_name = "your-d1-database-name"
database_id = "PASTE_YOUR_D1_DATABASE_ID_HERE"

[vars]
ALLOWED_ORIGIN = "https://<your-username>.github.io"

# SHARED_SECRET is set with `wrangler secret put SHARED_SECRET`,
# not in this file. For local dev, put it in worker/.dev.vars.
